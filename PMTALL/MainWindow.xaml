<Window x:Class="PMTALL.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:PMTALL.ViewModels"
        xmlns:conv="clr-namespace:PMTALL.Converters"
        xmlns:models="clr-namespace:PMTALL.Models"
        mc:Ignorable="d"
        Title="DICOM Toolkits" Height="820" Width="1200"
        Icon="/sources/favicon.ico"
        WindowStyle="None" ResizeMode="CanResize"
        Background="#1A1A2E"
        TextOptions.TextFormattingMode="Display"
        StateChanged="Window_StateChanged"
        d:DataContext="{d:DesignInstance vm:MainViewModel, IsDesignTimeCreatable=False}">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="48" CornerRadius="12"
                      GlassFrameThickness="0" ResizeBorderThickness="6"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/DarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
            <conv:BoolInverseConverter x:Key="BoolInverse"/>
            <conv:OperationTypeToDescriptionConverter x:Key="OpDescConv"/>
            <conv:OperationTypeToColorConverter x:Key="OpColorConv"/>

            <!-- ===== Title Bar Button Styles ===== -->
            <!-- Local unfrozen brushes so ColorAnimation can work -->
            <SolidColorBrush x:Key="BtnBgNormal" Color="Transparent"/>
            <SolidColorBrush x:Key="BtnBgHover" Color="#2A2A3E"/>
            <SolidColorBrush x:Key="BtnBorderNormal" Color="Transparent"/>
            <SolidColorBrush x:Key="CloseBgHover" Color="#E63946"/>

            <Style x:Key="TitleBarBtnStyle" TargetType="Button">
                <Setter Property="Width" Value="48"/>
                <Setter Property="Height" Value="36"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="Background" Value="{StaticResource BtnBgNormal}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BtnBorderNormal}"/>
                <Setter Property="BorderThickness" Value="1.5"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" CornerRadius="8"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="False"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                <ColorAnimation Duration="0:0:0.4"
                                                                Storyboard.TargetName="Bg"
                                                                Storyboard.TargetProperty="BorderBrush.Color"
                                                                From="#FFFFFF" To="#00B4D8"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <ColorAnimation Duration="0:0:0.1"
                                                                Storyboard.TargetName="Bg"
                                                                Storyboard.TargetProperty="Background.Color"
                                                                To="#2A2A3E"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <ColorAnimation Duration="0:0:0.15"
                                                                Storyboard.TargetName="Bg"
                                                                Storyboard.TargetProperty="BorderBrush.Color"
                                                                To="Transparent"/>
                                                <ColorAnimation Duration="0:0:0.1"
                                                                Storyboard.TargetName="Bg"
                                                                Storyboard.TargetProperty="Background.Color"
                                                                To="Transparent"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="CloseBtnStyle" TargetType="Button">
                <Setter Property="Width" Value="48"/>
                <Setter Property="Height" Value="36"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="Background" Value="{StaticResource BtnBgNormal}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BtnBorderNormal}"/>
                <Setter Property="BorderThickness" Value="1.5"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" CornerRadius="8"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="False"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                <ColorAnimation Duration="0:0:0.4"
                                                                Storyboard.TargetName="Bg"
                                                                Storyboard.TargetProperty="BorderBrush.Color"
                                                                From="#FFFFFF" To="#FF6B6B"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <ColorAnimation Duration="0:0:0.12"
                                                                Storyboard.TargetName="Bg"
                                                                Storyboard.TargetProperty="Background.Color"
                                                                To="#E63946"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <ColorAnimation Duration="0:0:0.15"
                                                                Storyboard.TargetName="Bg"
                                                                Storyboard.TargetProperty="BorderBrush.Color"
                                                                To="Transparent"/>
                                                <ColorAnimation Duration="0:0:0.3"
                                                                Storyboard.TargetName="Bg"
                                                                Storyboard.TargetProperty="Background.Color"
                                                                To="Transparent"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <!-- Main outer border with OS shadow (WindowChrome provides corner clipping) -->
    <Border Background="{StaticResource BgDarkBrush}"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">

        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ===== Title Bar ===== -->
            <Grid Grid.Row="0" Background="{StaticResource SurfaceBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto" MinWidth="136"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Margin="16,13,16,13">
                    <TextBlock Text="⚡" FontSize="18" Foreground="{StaticResource AccentBrush}" Margin="0,0,8,0"/>
                    <TextBlock Text="DICOM Toolkits" FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text=" v3.2.lijc" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="6,2,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,20,0"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button x:Name="MinimizeBtn" Style="{StaticResource TitleBarBtnStyle}"
                            Click="Minimize_Click" ToolTip="Minimize">
                        <TextBlock Text="−" FontSize="18" Foreground="White"/>
                    </Button>
                    <Button x:Name="MaximizeBtn" Style="{StaticResource TitleBarBtnStyle}"
                            Click="Maximize_Click" ToolTip="Maximize">
                        <Path x:Name="MaximizeIcon" Width="12" Height="12" Stretch="Uniform"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.5"
                              Data="M2,2 L10,2 L10,10 L2,10 Z"/>
                    </Button>
                    <Button x:Name="CloseBtn" Style="{StaticResource CloseBtnStyle}"
                            Click="Close_Click" ToolTip="Close">
                        <TextBlock Text="✕" FontSize="16" Foreground="White" FontWeight="Bold"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- ===== Main Content: Left Nav + Right Panel ===== -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="56"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ===== Left Vertical Tab Navigation ===== -->
                <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                    <StackPanel VerticalAlignment="Center" Margin="0,8,0,0">
                        <!-- Sort Tab -->
                        <Border x:Name="SortTabBtn" Background="Transparent"
                                ToolTip="Sort Mode" Cursor="Hand">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSortMode}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource BgLightBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel MouseLeftButtonDown="SortTab_Click">
                                <Grid Width="40" Height="40">
                                    <TextBlock Text="≡" FontSize="22"
                                               HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSortMode}" Value="True">
                                                        <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                                <TextBlock Text="Sort" FontSize="9"
                                           HorizontalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSortMode}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Height="1" Background="{StaticResource BorderBrush}" Margin="8,4"/>

                        <!-- Classify Tab -->
                        <Border ToolTip="Classify Mode" Cursor="Hand">
                            <StackPanel MouseLeftButtonDown="ClassifyTab_Click">
                                <Grid Width="40" Height="40">
                                    <TextBlock Text="◎" FontSize="20"
                                               HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsClassifyMode}" Value="True">
                                                        <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                                <TextBlock Text="Classify" FontSize="9"
                                           HorizontalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsClassifyMode}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Height="1" Background="{StaticResource BorderBrush}" Margin="8,4"/>

                        <!-- Statistics Tab -->
                        <Border ToolTip="Statistics Mode" Cursor="Hand">
                            <StackPanel MouseLeftButtonDown="StatsTab_Click">
                                <Grid Width="40" Height="40">
                                    <TextBlock Text="📊" FontSize="18"
                                               HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsStatisticsMode}" Value="True">
                                                        <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                                <TextBlock Text="Stats" FontSize="9"
                                           HorizontalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsStatisticsMode}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Height="1" Background="{StaticResource BorderBrush}" Margin="8,4"/>

                        <!-- DoseFix Tab -->
                        <Border ToolTip="DoseFix Mode" Cursor="Hand">
                            <StackPanel MouseLeftButtonDown="DoseFixTab_Click">
                                <Grid Width="40" Height="40">
                                    <TextBlock Text="💉" FontSize="16"
                                               HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDoseFixMode}" Value="True">
                                                        <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                                <TextBlock Text="DoseFix" FontSize="9"
                                           HorizontalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDoseFixMode}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Height="1" Background="{StaticResource BorderBrush}" Margin="8,4"/>

                        <!-- RawToDicom Tab -->
                        <Border ToolTip="Raw→DICOM Mode" Cursor="Hand">
                            <StackPanel MouseLeftButtonDown="RawToDicomTab_Click">
                                <Grid Width="40" Height="40">
                                    <TextBlock Text="⇄" FontSize="18"
                                               HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsRawToDicomMode}" Value="True">
                                                        <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                                <TextBlock Text="Raw2DCM" FontSize="8"
                                           HorizontalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRawToDicomMode}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Height="1" Background="{StaticResource BorderBrush}" Margin="8,4"/>

                        <!-- Viewer Tab -->
                        <Border ToolTip="DICOM Viewer" Cursor="Hand">
                            <StackPanel MouseLeftButtonDown="ViewerTab_Click">
                                <Grid Width="40" Height="40">
                                    <TextBlock Text="🔍" FontSize="16"
                                               HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsViewerMode}" Value="True">
                                                        <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                                <TextBlock Text="Viewer" FontSize="8"
                                           HorizontalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsViewerMode}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ===== Right Content Panel ===== -->
                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto"
                              Background="{StaticResource BgDarkBrush}"
                              BorderThickness="0">
                    <Grid Margin="20,12,20,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- ===== SORT MODE PANEL ===== -->
                        <Grid Grid.Row="0" Visibility="{Binding IsSortMode, Converter={StaticResource BoolToVis}}"
                              IsEnabled="{Binding IsSortMode}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Mode Toggle -->
                            <Border Grid.Row="0" Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border CornerRadius="8" Background="{StaticResource SurfaceLightBrush}"
                                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="4">
                                        <StackPanel Orientation="Horizontal">
                                            <RadioButton x:Name="SortModeRadio"
                                                         IsChecked="{Binding IsSortMode}"
                                                         Padding="20,8" FontSize="14"
                                                         Background="Transparent"
                                                         MinWidth="120" HorizontalContentAlignment="Center">
                                                <RadioButton.Resources>
                                                    <Style TargetType="RadioButton" BasedOn="{StaticResource {x:Type RadioButton}}">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="RadioButton">
                                                                    <Border x:Name="Bg" Background="Transparent" CornerRadius="6"
                                                                            BorderThickness="0" Padding="20,8">
                                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                                          VerticalAlignment="Center"
                                                                                          TextElement.Foreground="{StaticResource TextSecondaryBrush}"/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsChecked" Value="True">
                                                                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource BgLightBrush}"/>
                                                                            <Setter Property="TextElement.Foreground" Value="{StaticResource AccentBrush}"/>
                                                                        </Trigger>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter Property="TextElement.Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </RadioButton.Resources>
                                                <TextBlock Text="Sort Mode" FontWeight="SemiBold"/>
                                            </RadioButton>

                                            <RadioButton IsChecked="{Binding IsClassifyMode}"
                                                         Padding="20,8" FontSize="14"
                                                         Background="Transparent"
                                                         MinWidth="120" HorizontalContentAlignment="Center">
                                                <RadioButton.Resources>
                                                    <Style TargetType="RadioButton" BasedOn="{StaticResource {x:Type RadioButton}}">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="RadioButton">
                                                                    <Border x:Name="Bg" Background="Transparent" CornerRadius="6"
                                                                            BorderThickness="0" Padding="20,8">
                                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                                          VerticalAlignment="Center"
                                                                                          TextElement.Foreground="{StaticResource TextSecondaryBrush}"/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsChecked" Value="True">
                                                                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource BgLightBrush}"/>
                                                                            <Setter Property="TextElement.Foreground" Value="{StaticResource AccentBrush}"/>
                                                                        </Trigger>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter Property="TextElement.Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </RadioButton.Resources>
                                                <TextBlock Text="Classify Mode" FontWeight="SemiBold"/>
                                            </RadioButton>
                                        </StackPanel>
                                    </Border>

                                    <TextBlock Grid.Column="1" Text="{Binding ProgressStatus, FallbackValue='Ready'}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="12"/>
                                </Grid>
                            </Border>

                            <!-- Source Folder -->
                            <Border Grid.Row="1" Style="{StaticResource CardPanel}" Margin="0,0,0,12"
                                    AllowDrop="True"
                                    x:Name="SortDropBorder">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="SOURCE FOLDER" Style="{StaticResource SectionTitle}" Margin="0,0,0,8"/>
                                    <Grid Grid.Row="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" x:Name="DropBorder"
                                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                                CornerRadius="6" Background="{StaticResource SurfaceBrush}"
                                                Padding="12,8" Margin="0,0,8,0" AllowDrop="True"
                                                ToolTip="Drag &amp; drop a folder here or click Browse">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="📁" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding SourceFolder, FallbackValue='Select a folder...'}"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </Grid>
                                        </Border>
                                        <Button Grid.Column="1" Content="Browse..."
                                                Command="{Binding SelectSourceFolderCommand}" MinWidth="100"/>
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- Sort Options -->
                            <Border Grid.Row="2" Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="SORT OPTIONS" Style="{StaticResource SectionTitle}" Margin="0,0,0,8"/>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Row="0" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,0,0,8">
                                            <CheckBox IsChecked="{Binding SortInPlace}" Content="In-place (rename + modify time)"
                                                      Margin="0,0,24,0"
                                                      Foreground="{StaticResource TextPrimaryBrush}"/>
                                        </StackPanel>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Target Folder:" Style="{StaticResource OptionLabel}"/>
                                        <TextBox Grid.Row="1" Grid.Column="1"
                                                 Text="{Binding SortTargetFolder, UpdateSourceTrigger=PropertyChanged}"
                                                 Margin="0,0,8,8" IsReadOnly="True"/>
                                        <Button Grid.Row="1" Grid.Column="2" Content="Browse..."
                                                Command="{Binding SelectSortTargetFolderCommand}"
                                                Margin="0,0,0,8" Padding="12,6"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Base Time:" Style="{StaticResource OptionLabel}"/>
                                        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,0,8,0">
                                            <ComboBox ItemsSource="{Binding Years}" SelectedItem="{Binding SortYear}"
                                                      Width="100" FontSize="15" HorizontalContentAlignment="Center"
                                                      Background="{StaticResource BgMediumBrush}" Foreground="White"
                                                      BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"/>
                                            <TextBlock Text="/" VerticalAlignment="Center" Foreground="White" FontSize="16" FontWeight="Bold" Margin="4,0"/>
                                            <ComboBox ItemsSource="{Binding Months}" SelectedItem="{Binding SortMonth}"
                                                      Width="64" FontSize="15" HorizontalContentAlignment="Center"
                                                      Background="{StaticResource BgMediumBrush}" Foreground="White"
                                                      BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"/>
                                            <TextBlock Text="/" VerticalAlignment="Center" Foreground="White" FontSize="16" FontWeight="Bold" Margin="4,0"/>
                                            <ComboBox ItemsSource="{Binding Days}" SelectedItem="{Binding SortDay}"
                                                      Width="64" FontSize="15" HorizontalContentAlignment="Center"
                                                      Background="{StaticResource BgMediumBrush}" Foreground="White"
                                                      BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"/>
                                            <TextBlock Text="  " VerticalAlignment="Center" Foreground="White" FontSize="16" Margin="4,0,0,0"/>
                                            <ComboBox ItemsSource="{Binding Hours}" SelectedItem="{Binding SortHour}"
                                                      Width="64" FontSize="15" HorizontalContentAlignment="Center"
                                                      Background="{StaticResource BgMediumBrush}" Foreground="White"
                                                      BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"/>
                                            <TextBlock Text=":" VerticalAlignment="Center" Foreground="White" FontSize="16" FontWeight="Bold" Margin="4,0"/>
                                            <ComboBox ItemsSource="{Binding Minutes}" SelectedItem="{Binding SortMinute}"
                                                      Width="64" FontSize="15" HorizontalContentAlignment="Center"
                                                      Background="{StaticResource BgMediumBrush}" Foreground="White"
                                                      BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Action Buttons -->
                            <Border Grid.Row="3" Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding ScanSummary}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               VerticalAlignment="Center" FontSize="12"/>
                                    <Button Grid.Column="1" Content="Clear Log" Command="{Binding ClearLogCommand}"
                                            Margin="0,0,8,0" Padding="14,8" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <Button Grid.Column="2" Content="Scan &amp; Preview"
                                            Command="{Binding ScanAndPreviewCommand}"
                                            IsEnabled="{Binding IsScanning, Converter={StaticResource BoolToVis}, ConverterParameter=invert}"
                                            Style="{StaticResource AccentButton}" Margin="0,0,8,0" MinWidth="140"/>
                                    <Button Grid.Column="3" Content="▶ Execute" Command="{Binding ExecuteOperationsCommand}"
                                            IsEnabled="{Binding HasPreview}" Style="{StaticResource AccentButton}" MinWidth="120"/>
                                </Grid>
                            </Border>

                            <!-- Preview Area -->
                            <Border Grid.Row="4" Style="{StaticResource CardPanel}"
                                    Visibility="{Binding HasPreview, Converter={StaticResource BoolToVis}}" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="PREVIEW - Operations to perform" Style="{StaticResource SectionTitle}" Margin="0,0,0,8"/>
                                        <TextBlock Grid.Column="1" Text="{Binding CurrentPlan.Summary, FallbackValue='0 operations'}"
                                                   Foreground="{StaticResource AccentLightBrush}" VerticalAlignment="Center" FontSize="12"/>
                                    </Grid>
                                    <DataGrid Grid.Row="1" ItemsSource="{Binding PreviewOperations}" AutoGenerateColumns="False"
                                              IsReadOnly="True" Background="{StaticResource SurfaceBrush}"
                                              BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                              RowHeaderWidth="0" GridLinesVisibility="Horizontal" MaxHeight="400"
                                              Foreground="{StaticResource TextPrimaryBrush}"
                                              VirtualizingPanel.IsVirtualizing="True"
                                              ScrollViewer.CanContentScroll="True"
                                              VirtualizingPanel.VirtualizationMode="Recycling">
                                        <DataGrid.Resources>
                                            <Style TargetType="DataGridColumnHeader">
                                                <Setter Property="Background" Value="{StaticResource SurfaceLightBrush}"/>
                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="Padding" Value="8,6"/>
                                            </Style>
                                            <Style TargetType="DataGridCell">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                                <Setter Property="Padding" Value="8,4"/>
                                            </Style>
                                            <Style TargetType="DataGridRow">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <Trigger Property="AlternationIndex" Value="0">
                                                        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
                                                    </Trigger>
                                                    <Trigger Property="AlternationIndex" Value="1">
                                                        <Setter Property="Background" Value="{StaticResource SurfaceLightBrush}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGrid.Resources>
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Type" Width="100" Binding="{Binding Type}"/>
                                            <DataGridTextColumn Header="Description" Width="*" Binding="{Binding Description}"/>
                                            <DataGridTextColumn Header="Details" Width="250">
                                                <DataGridTextColumn.Binding>
                                                    <Binding Path="." Converter="{StaticResource OpDescConv}"/>
                                                </DataGridTextColumn.Binding>
                                            </DataGridTextColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                    <Button Grid.Row="2" Content="Cancel Preview" Command="{Binding CancelPreviewCommand}"
                                            Style="{StaticResource DangerButton}" Margin="0,8,0,0" HorizontalAlignment="Left"/>
                                </Grid>
                            </Border>

                            <!-- Log Panel -->
                            <Border Grid.Row="5" Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="LOG" Style="{StaticResource SectionTitle}" Margin="0,0,0,4"/>
                                    <ListBox Grid.Row="1" ItemsSource="{Binding LogEntries}" MaxHeight="140"
                                             Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}"
                                             BorderThickness="1" FontFamily="Consolas" FontSize="11"
                                             Foreground="{StaticResource TextSecondaryBrush}"
                                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                             VirtualizingPanel.IsVirtualizing="True"
                                             VirtualizingPanel.VirtualizationMode="Recycling">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" TextWrapping="NoWrap"/>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- ===== CLASSIFY MODE PANEL ===== -->
                        <Grid Grid.Row="0" Visibility="{Binding IsClassifyMode, Converter={StaticResource BoolToVis}}"
                              IsEnabled="{Binding IsClassifyMode}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Mode Toggle (same as sort mode) -->
                            <Border Grid.Row="0" Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border CornerRadius="8" Background="{StaticResource SurfaceLightBrush}"
                                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="4">
                                        <StackPanel Orientation="Horizontal">
                                            <RadioButton IsChecked="{Binding IsSortMode}" Padding="20,8" FontSize="14"
                                                         Background="Transparent" MinWidth="120" HorizontalContentAlignment="Center">
                                                <RadioButton.Resources>
                                                    <Style TargetType="RadioButton" BasedOn="{StaticResource {x:Type RadioButton}}">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="RadioButton">
                                                                    <Border x:Name="Bg" Background="Transparent" CornerRadius="6"
                                                                            BorderThickness="0" Padding="20,8">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                                          TextElement.Foreground="{StaticResource TextSecondaryBrush}"/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsChecked" Value="True">
                                                                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource BgLightBrush}"/>
                                                                            <Setter Property="TextElement.Foreground" Value="{StaticResource AccentBrush}"/>
                                                                        </Trigger>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter Property="TextElement.Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </RadioButton.Resources>
                                                <TextBlock Text="Sort Mode" FontWeight="SemiBold"/>
                                            </RadioButton>
                                            <RadioButton IsChecked="{Binding IsClassifyMode}" Padding="20,8" FontSize="14"
                                                         Background="Transparent" MinWidth="120" HorizontalContentAlignment="Center">
                                                <RadioButton.Resources>
                                                    <Style TargetType="RadioButton" BasedOn="{StaticResource {x:Type RadioButton}}">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="RadioButton">
                                                                    <Border x:Name="Bg" Background="Transparent" CornerRadius="6"
                                                                            BorderThickness="0" Padding="20,8">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                                          TextElement.Foreground="{StaticResource TextSecondaryBrush}"/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsChecked" Value="True">
                                                                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource BgLightBrush}"/>
                                                                            <Setter Property="TextElement.Foreground" Value="{StaticResource AccentBrush}"/>
                                                                        </Trigger>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter Property="TextElement.Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </RadioButton.Resources>
                                                <TextBlock Text="Classify Mode" FontWeight="SemiBold"/>
                                            </RadioButton>
                                        </StackPanel>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="{Binding ProgressStatus, FallbackValue='Ready'}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="12"/>
                                </Grid>
                            </Border>

                            <!-- Source Folder -->
                            <Border Grid.Row="1" Style="{StaticResource CardPanel}" Margin="0,0,0,12" AllowDrop="True">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="SOURCE FOLDER" Style="{StaticResource SectionTitle}" Margin="0,0,0,8"/>
                                    <Grid Grid.Row="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                                CornerRadius="6" Background="{StaticResource SurfaceBrush}"
                                                Padding="12,8" Margin="0,0,8,0" AllowDrop="True"
                                                ToolTip="Drag &amp; drop a folder here or click Browse">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="📁" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding SourceFolder, FallbackValue='Select a folder...'}"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                            </Grid>
                                        </Border>
                                        <Button Grid.Column="1" Content="Browse..." Command="{Binding SelectSourceFolderCommand}" MinWidth="100"/>
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- Classify Options -->
                            <Border Grid.Row="2" Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="CLASSIFY OPTIONS" Style="{StaticResource SectionTitle}" Margin="0,0,0,8"/>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="160"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Top-level Structure:" Style="{StaticResource OptionLabel}"/>
                                        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,8">
                                            <RadioButton IsChecked="{Binding UseYearMonth}" Content="Year / Month → Patient" Margin="0,0,24,0"/>
                                            <RadioButton IsChecked="{Binding UseDirectPatient}" Content="Direct by Patient"/>
                                        </StackPanel>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Patient Folder:" Style="{StaticResource OptionLabel}"/>
                                        <ComboBox Grid.Row="1" Grid.Column="1"
                                                  ItemsSource="{Binding NamingRules}"
                                                  SelectedIndex="{Binding SelectedNamingRuleIndex}"
                                                  Margin="0,0,0,8" HorizontalAlignment="Left" MinWidth="300"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Output Root:" Style="{StaticResource OptionLabel}"/>
                                        <Grid Grid.Row="2" Grid.Column="1" Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Text="{Binding SortTargetFolder, UpdateSourceTrigger=PropertyChanged}"
                                                     IsReadOnly="True" Margin="0,0,8,0"/>
                                            <Button Grid.Column="1" Content="Browse..." Command="{Binding SelectSortTargetFolderCommand}" Padding="12,6"/>
                                        </Grid>

                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Extra:" Style="{StaticResource OptionLabel}"/>
                                        <StackPanel Grid.Row="3" Grid.Column="1">
                                            <CheckBox IsChecked="{Binding EnableSortWithinPatient}"
                                                      Content="Sort files within each Series (rename with prefix)"/>
                                            <CheckBox IsChecked="{Binding UsePatientDateModality}"
                                                      Content="Patient → Date → Modality (CT/CBCT detection via Manufacturer's Model Name)"
                                                      Margin="0,4,0,0"/>
                                            <CheckBox IsChecked="{Binding UseSpecialDateMode}"
                                                      Content="Special Date Mode: use RT tags as date base"
                                                      Margin="16,4,0,0"
                                                      Visibility="{Binding UsePatientDateModality, Converter={StaticResource BoolToVis}}"/>
                                            <ComboBox ItemsSource="{Binding SpecialDateOptionList}"
                                                      SelectedIndex="{Binding SelectedSpecialDateIndex}"
                                                      DisplayMemberPath="DisplayName"
                                                      Margin="32,4,0,0"
                                                      Visibility="{Binding IsSpecialComboVisible, Converter={StaticResource BoolToVis}}"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Action Buttons -->
                            <Border Grid.Row="3" Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding ScanSummary}"
                                               Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" FontSize="12"/>
                                    <Button Grid.Column="1" Content="Clear Log" Command="{Binding ClearLogCommand}"
                                            Margin="0,0,8,0" Padding="14,8" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <Button Grid.Column="2" Content="Scan &amp; Preview"
                                            Command="{Binding ScanAndPreviewCommand}"
                                            IsEnabled="{Binding IsScanning, Converter={StaticResource BoolToVis}, ConverterParameter=invert}"
                                            Style="{StaticResource AccentButton}" Margin="0,0,8,0" MinWidth="140"/>
                                    <Button Grid.Column="3" Content="▶ Execute" Command="{Binding ExecuteOperationsCommand}"
                                            IsEnabled="{Binding HasPreview}" Style="{StaticResource AccentButton}" MinWidth="120"/>
                                </Grid>
                            </Border>

                            <!-- Preview Area -->
                            <Border Grid.Row="4" Style="{StaticResource CardPanel}"
                                    Visibility="{Binding HasPreview, Converter={StaticResource BoolToVis}}" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="PREVIEW - Operations to perform" Style="{StaticResource SectionTitle}" Margin="0,0,0,8"/>
                                        <TextBlock Grid.Column="1" Text="{Binding CurrentPlan.Summary, FallbackValue='0 operations'}"
                                                   Foreground="{StaticResource AccentLightBrush}" VerticalAlignment="Center" FontSize="12"/>
                                    </Grid>
                                    <DataGrid Grid.Row="1" ItemsSource="{Binding PreviewOperations}" AutoGenerateColumns="False"
                                              IsReadOnly="True" Background="{StaticResource SurfaceBrush}"
                                              BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                              RowHeaderWidth="0" GridLinesVisibility="Horizontal" MaxHeight="400"
                                              Foreground="{StaticResource TextPrimaryBrush}"
                                              VirtualizingPanel.IsVirtualizing="True"
                                              ScrollViewer.CanContentScroll="True"
                                              VirtualizingPanel.VirtualizationMode="Recycling">
                                        <DataGrid.Resources>
                                            <Style TargetType="DataGridColumnHeader">
                                                <Setter Property="Background" Value="{StaticResource SurfaceLightBrush}"/>
                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="Padding" Value="8,6"/>
                                            </Style>
                                            <Style TargetType="DataGridCell">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                                <Setter Property="Padding" Value="8,4"/>
                                            </Style>
                                            <Style TargetType="DataGridRow">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <Trigger Property="AlternationIndex" Value="0">
                                                        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
                                                    </Trigger>
                                                    <Trigger Property="AlternationIndex" Value="1">
                                                        <Setter Property="Background" Value="{StaticResource SurfaceLightBrush}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGrid.Resources>
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Type" Width="100" Binding="{Binding Type}"/>
                                            <DataGridTextColumn Header="Description" Width="*" Binding="{Binding Description}"/>
                                            <DataGridTextColumn Header="Details" Width="250">
                                                <DataGridTextColumn.Binding>
                                                    <Binding Path="." Converter="{StaticResource OpDescConv}"/>
                                                </DataGridTextColumn.Binding>
                                            </DataGridTextColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                    <Button Grid.Row="2" Content="Cancel Preview" Command="{Binding CancelPreviewCommand}"
                                            Style="{StaticResource DangerButton}" Margin="0,8,0,0" HorizontalAlignment="Left"/>
                                </Grid>
                            </Border>

                            <!-- Log Panel -->
                            <Border Grid.Row="5" Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="LOG" Style="{StaticResource SectionTitle}" Margin="0,0,0,4"/>
                                    <ListBox Grid.Row="1" ItemsSource="{Binding LogEntries}" MaxHeight="140"
                                             Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}"
                                             BorderThickness="1" FontFamily="Consolas" FontSize="11"
                                             Foreground="{StaticResource TextSecondaryBrush}"
                                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                             VirtualizingPanel.IsVirtualizing="True"
                                             VirtualizingPanel.VirtualizationMode="Recycling">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" TextWrapping="NoWrap"/>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- ===== STATISTICS MODE PANEL ===== -->
                        <Grid Grid.Row="0"
                              DataContext="{Binding Statistics}"
                              Visibility="{Binding DataContext.IsStatisticsMode, Converter={StaticResource BoolToVis}, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}}}"
                              IsEnabled="{Binding DataContext.IsStatisticsMode, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Top Section: Source folder + Actions -->
                            <Border Grid.Row="0" Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="STATISTICS" Style="{StaticResource SectionTitle}" Margin="0,0,0,8"/>

                                    <!-- Source folder -->
                                    <Grid Grid.Row="1" Grid.ColumnSpan="2" Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                                CornerRadius="6" Background="{StaticResource SurfaceBrush}"
                                                Padding="12,8" Margin="0,0,8,0" AllowDrop="True"
                                                ToolTip="Drag &amp; drop a folder here or click Browse">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="📁" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding SourceFolder, FallbackValue='Select a folder...'}"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                            </Grid>
                                        </Border>
                                        <Button Grid.Column="1" Content="Browse..."
                                                Command="{Binding SelectSourceFolderCommand}" MinWidth="100"/>
                                    </Grid>

                                    <!-- Action bar -->
                                    <Grid Grid.Row="2" Grid.ColumnSpan="2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="{Binding ScanSummary}"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center" FontSize="12"/>

                                        <Button Grid.Column="1" Content="Clear Log"
                                                Command="{Binding ClearLogCommand}"
                                                Margin="0,0,8,0" Padding="14,8"
                                                Foreground="{StaticResource TextSecondaryBrush}"/>

                                        <Button Grid.Column="2" Content="Start Statistics"
                                                Command="{Binding StartStatisticsCommand}"
                                                IsEnabled="{Binding IsScanning, Converter={StaticResource BoolToVis}, ConverterParameter=invert}"
                                                Style="{StaticResource AccentButton}" Margin="0,0,8,0" MinWidth="140"/>

                                        <!-- Export buttons -->
                                        <Button Grid.Column="3" Content="Excel"
                                                Command="{Binding ExportCommand}" CommandParameter="excel"
                                                IsEnabled="{Binding HasResults}"
                                                Style="{StaticResource AccentButton}" Margin="0,0,4,0" MinWidth="60" FontSize="11"/>

                                        <Button Grid.Column="4" Content="JSON"
                                                Command="{Binding ExportCommand}" CommandParameter="json"
                                                IsEnabled="{Binding HasResults}"
                                                Style="{StaticResource AccentButton}" Margin="0,0,4,0" MinWidth="60" FontSize="11"/>

                                        <Button Grid.Column="5" Content="CSV"
                                                Command="{Binding ExportCommand}" CommandParameter="csv"
                                                IsEnabled="{Binding HasResults}"
                                                Style="{StaticResource AccentButton}" MinWidth="60" FontSize="11"/>
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- Main Statistics Content: Left checklist + Right results -->
                            <Border Grid.Row="1" Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="280"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Left panel: Stat item checklist -->
                                    <Border Grid.Column="0" BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="0,0,1,0" Padding="0,0,12,0">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <Grid Grid.Row="0" Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="STATISTICS ITEMS" Style="{StaticResource SectionTitle}" Margin="0,0,0,0"/>
                                            </Grid>

                                            <ListBox Grid.Row="1" ItemsSource="{Binding StatItems}"
                                                     Background="{StaticResource SurfaceBrush}"
                                                     BorderBrush="{StaticResource BorderBrush}"
                                                     BorderThickness="1"
                                                     VirtualizingPanel.IsVirtualizing="True"
                                                     VirtualizingPanel.VirtualizationMode="Recycling">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate DataType="models:StatItem">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <CheckBox IsChecked="{Binding IsChecked}" Margin="0,0,8,0"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                                       FontSize="12" VerticalAlignment="Center"/>
                                                            <TextBlock Grid.Column="2" Text="{Binding ComputedValue}"
                                                                       Foreground="{StaticResource AccentLightBrush}"
                                                                       FontSize="11" VerticalAlignment="Center"
                                                                       FontFamily="Consolas"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </Grid>
                                    </Border>

                                    <!-- Right panel: Results DataGrid -->
                                    <Grid Grid.Column="1" Margin="12,0,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0" Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="RESULTS" Style="{StaticResource SectionTitle}" Margin="0,0,0,0"/>
                                        </Grid>

                                        <DataGrid Grid.Row="1" ItemsSource="{Binding StatItems}"
                                                  AutoGenerateColumns="False" IsReadOnly="True"
                                                  Background="{StaticResource SurfaceBrush}"
                                                  BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                                  RowHeaderWidth="0" GridLinesVisibility="Horizontal"
                                                  Foreground="{StaticResource TextPrimaryBrush}"
                                                  CanUserSortColumns="True"
                                                  VirtualizingPanel.IsVirtualizing="True"
                                                  ScrollViewer.CanContentScroll="True"
                                                  VirtualizingPanel.VirtualizationMode="Recycling">
                                            <DataGrid.Resources>
                                                <Style TargetType="DataGridColumnHeader">
                                                    <Setter Property="Background" Value="{StaticResource SurfaceLightBrush}"/>
                                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                                    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                    <Setter Property="Padding" Value="8,6"/>
                                                </Style>
                                                <Style TargetType="DataGridCell">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                                    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                                    <Setter Property="Padding" Value="8,4"/>
                                                </Style>
                                                <Style TargetType="DataGridRow">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="AlternationIndex" Value="0">
                                                            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
                                                        </Trigger>
                                                        <Trigger Property="AlternationIndex" Value="1">
                                                            <Setter Property="Background" Value="{StaticResource SurfaceLightBrush}"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </DataGrid.Resources>
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Statistic" Width="*" Binding="{Binding Name}"/>
                                                <DataGridTextColumn Header="Value" Width="Auto" Binding="{Binding ComputedValue}" MinWidth="200"/>
                                                <DataGridTextColumn Header="Category" Width="100" Binding="{Binding Category}"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- Statistics Log Panel -->
                            <Border Grid.Row="2" Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="LOG" Style="{StaticResource SectionTitle}" Margin="0,0,0,4"/>
                                    <ListBox Grid.Row="1" ItemsSource="{Binding LogEntries}" MaxHeight="100"
                                             Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}"
                                             BorderThickness="1" FontFamily="Consolas" FontSize="11"
                                             Foreground="{StaticResource TextSecondaryBrush}"
                                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                             VirtualizingPanel.IsVirtualizing="True"
                                             VirtualizingPanel.VirtualizationMode="Recycling">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" TextWrapping="NoWrap"/>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- ===== DOSEFIX MODE PANEL ===== -->
                        <Grid Grid.Row="0" Visibility="{Binding IsDoseFixMode, Converter={StaticResource BoolToVis}}"
                              IsEnabled="{Binding IsDoseFixMode}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Mode Toggle: Normal / Enhance -->
                            <Border Grid.Row="0" Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border CornerRadius="8" Background="{StaticResource SurfaceLightBrush}"
                                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="4">
                                        <StackPanel Orientation="Horizontal">
                                            <RadioButton IsChecked="{Binding DoseFixEnhanceMode}"
                                                         Padding="20,8" FontSize="14"
                                                         Background="Transparent"
                                                         MinWidth="120" HorizontalContentAlignment="Center">
                                                <RadioButton.Resources>
                                                    <Style TargetType="RadioButton" BasedOn="{StaticResource {x:Type RadioButton}}">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="RadioButton">
                                                                    <Border x:Name="Bg" Background="Transparent" CornerRadius="6"
                                                                            BorderThickness="0" Padding="20,8">
                                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                                          VerticalAlignment="Center"
                                                                                          TextElement.Foreground="{StaticResource TextSecondaryBrush}"/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsChecked" Value="True">
                                                                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource BgLightBrush}"/>
                                                                            <Setter Property="TextElement.Foreground" Value="{StaticResource AccentBrush}"/>
                                                                        </Trigger>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter Property="TextElement.Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </RadioButton.Resources>
                                                <TextBlock Text="Enhance Mode" FontWeight="SemiBold"/>
                                            </RadioButton>

                                            <RadioButton IsChecked="{Binding DoseFixEnhanceMode, Converter={StaticResource BoolInverse}}"
                                                         Padding="20,8" FontSize="14"
                                                         Background="Transparent"
                                                         MinWidth="120" HorizontalContentAlignment="Center">
                                                <RadioButton.Resources>
                                                    <Style TargetType="RadioButton" BasedOn="{StaticResource {x:Type RadioButton}}">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="RadioButton">
                                                                    <Border x:Name="Bg" Background="Transparent" CornerRadius="6"
                                                                            BorderThickness="0" Padding="20,8">
                                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                                          VerticalAlignment="Center"
                                                                                          TextElement.Foreground="{StaticResource TextSecondaryBrush}"/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsChecked" Value="True">
                                                                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource BgLightBrush}"/>
                                                                            <Setter Property="TextElement.Foreground" Value="{StaticResource AccentBrush}"/>
                                                                        </Trigger>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter Property="TextElement.Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </RadioButton.Resources>
                                                <TextBlock Text="Normal Mode" FontWeight="SemiBold"/>
                                            </RadioButton>
                                        </StackPanel>
                                    </Border>

                                    <TextBlock Grid.Column="1" Text="{Binding ProgressStatus, FallbackValue='Ready'}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="12"/>
                                </Grid>
                            </Border>

                            <!-- Source Folder -->
                            <Border Grid.Row="1" Style="{StaticResource CardPanel}" Margin="0,0,0,12" AllowDrop="True">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="SOURCE FOLDER" Style="{StaticResource SectionTitle}" Margin="0,0,0,8"/>
                                    <Grid Grid.Row="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                                CornerRadius="6" Background="{StaticResource SurfaceBrush}"
                                                Padding="12,8" Margin="0,0,8,0" AllowDrop="True"
                                                ToolTip="Drag &amp; drop a folder here or click Browse">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="📁" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding SourceFolder, FallbackValue='Select a folder...'}"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                            </Grid>
                                        </Border>
                                        <Button Grid.Column="1" Content="Browse..."
                                                Command="{Binding SelectSourceFolderCommand}" MinWidth="100"/>
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- Target Folder -->
                            <Border Grid.Row="2" Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="DOSEFIX OPTIONS" Style="{StaticResource SectionTitle}" Margin="0,0,0,8"/>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Target Folder:" Style="{StaticResource OptionLabel}"/>
                                        <TextBox Grid.Column="1"
                                                 Text="{Binding DoseFixTargetFolder, UpdateSourceTrigger=PropertyChanged}"
                                                 Margin="0,0,8,0" IsReadOnly="True"/>
                                        <Button Grid.Column="2" Content="Browse..."
                                                Command="{Binding SelectDoseFixTargetFolderCommand}" Padding="12,6"/>
                                    </Grid>
                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,4,0,0">
                                        <Run Text="Enhance mode uses CT IOP for spatial correction; Normal mode uses default IOP (1/0/0/0/1/0)."/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- Action Buttons -->
                            <Border Grid.Row="3" Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding ScanSummary}"
                                               Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" FontSize="12"/>
                                    <Button Grid.Column="1" Content="Clear Log" Command="{Binding ClearLogCommand}"
                                            Margin="0,0,8,0" Padding="14,8" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <Button Grid.Column="2" Content="Scan &amp; Preview"
                                            Command="{Binding ScanAndPreviewCommand}"
                                            IsEnabled="{Binding IsScanning, Converter={StaticResource BoolToVis}, ConverterParameter=invert}"
                                            Style="{StaticResource AccentButton}" Margin="0,0,8,0" MinWidth="140"/>
                                    <Button Grid.Column="3" Content="▶ Execute" Command="{Binding ExecuteOperationsCommand}"
                                            IsEnabled="{Binding HasPreview}" Style="{StaticResource AccentButton}" MinWidth="120"/>
                                </Grid>
                            </Border>

                            <!-- Preview Area -->
                            <Border Grid.Row="4" Style="{StaticResource CardPanel}"
                                    Visibility="{Binding HasPreview, Converter={StaticResource BoolToVis}}" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="PREVIEW - Operations to perform" Style="{StaticResource SectionTitle}" Margin="0,0,0,8"/>
                                        <TextBlock Grid.Column="1" Text="{Binding CurrentPlan.Summary, FallbackValue='0 operations'}"
                                                   Foreground="{StaticResource AccentLightBrush}" VerticalAlignment="Center" FontSize="12"/>
                                    </Grid>
                                    <DataGrid Grid.Row="1" ItemsSource="{Binding PreviewOperations}" AutoGenerateColumns="False"
                                              IsReadOnly="True" Background="{StaticResource SurfaceBrush}"
                                              BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                              RowHeaderWidth="0" GridLinesVisibility="Horizontal" MaxHeight="400"
                                              Foreground="{StaticResource TextPrimaryBrush}"
                                              VirtualizingPanel.IsVirtualizing="True"
                                              ScrollViewer.CanContentScroll="True"
                                              VirtualizingPanel.VirtualizationMode="Recycling">
                                        <DataGrid.Resources>
                                            <Style TargetType="DataGridColumnHeader">
                                                <Setter Property="Background" Value="{StaticResource SurfaceLightBrush}"/>
                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="Padding" Value="8,6"/>
                                            </Style>
                                            <Style TargetType="DataGridCell">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                                <Setter Property="Padding" Value="8,4"/>
                                            </Style>
                                            <Style TargetType="DataGridRow">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <Trigger Property="AlternationIndex" Value="0">
                                                        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
                                                    </Trigger>
                                                    <Trigger Property="AlternationIndex" Value="1">
                                                        <Setter Property="Background" Value="{StaticResource SurfaceLightBrush}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGrid.Resources>
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Type" Width="100" Binding="{Binding Type}"/>
                                            <DataGridTextColumn Header="Description" Width="*" Binding="{Binding Description}"/>
                                            <DataGridTextColumn Header="Details" Width="250">
                                                <DataGridTextColumn.Binding>
                                                    <Binding Path="." Converter="{StaticResource OpDescConv}"/>
                                                </DataGridTextColumn.Binding>
                                            </DataGridTextColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                    <Button Grid.Row="2" Content="Cancel Preview" Command="{Binding CancelPreviewCommand}"
                                            Style="{StaticResource DangerButton}" Margin="0,8,0,0" HorizontalAlignment="Left"/>
                                </Grid>
                            </Border>

                            <!-- Log Panel -->
                            <Border Grid.Row="5" Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="LOG" Style="{StaticResource SectionTitle}" Margin="0,0,0,4"/>
                                    <ListBox Grid.Row="1" ItemsSource="{Binding LogEntries}" MaxHeight="140"
                                             Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}"
                                             BorderThickness="1" FontFamily="Consolas" FontSize="11"
                                             Foreground="{StaticResource TextSecondaryBrush}"
                                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                             VirtualizingPanel.IsVirtualizing="True"
                                             VirtualizingPanel.VirtualizationMode="Recycling">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" TextWrapping="NoWrap"/>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- ===== RAW TO DICOM MODE PANEL ===== -->
                        <Grid Grid.Row="0" Visibility="{Binding IsRawToDicomMode, Converter={StaticResource BoolToVis}}"
                              IsEnabled="{Binding IsRawToDicomMode}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Mode Header -->
                            <Border Grid.Row="0" Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border CornerRadius="8" Background="{StaticResource SurfaceLightBrush}"
                                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="4">
                                        <StackPanel Orientation="Horizontal">
                                            <Border Background="{StaticResource BgLightBrush}" CornerRadius="6"
                                                    Padding="20,8">
                                                <TextBlock Text="Raw to DICOM" FontWeight="SemiBold"
                                                           Foreground="{StaticResource AccentBrush}"/>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="{Binding ProgressStatus, FallbackValue='Ready'}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="12"/>
                                </Grid>
                            </Border>

                            <!-- Source Raw File -->
                            <Border Grid.Row="1" Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="SOURCE RAW FILE" Style="{StaticResource SectionTitle}" Margin="0,0,0,8"/>
                                    <Grid Grid.Row="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" x:Name="RawFileDropBorder"
                                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                                CornerRadius="6" Background="{StaticResource SurfaceBrush}"
                                                Padding="12,8" Margin="0,0,8,0" AllowDrop="True"
                                                ToolTip="Drag &amp; drop a .raw file here or click Browse"
                                                Drop="RawFileDropBorder_Drop"
                                                DragOver="RawFileDropBorder_DragOver"
                                                DragLeave="RawFileDropBorder_DragLeave">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="📄" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding RawFileName, FallbackValue='Select a raw file...'}"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                            </Grid>
                                        </Border>
                                        <Button Grid.Column="1" Content="Browse..."
                                                Command="{Binding SelectRawFileCommand}" MinWidth="100"/>
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- DICOM Tag Configuration -->
                            <Border Grid.Row="2" Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="DICOM TAG CONFIGURATION" Style="{StaticResource SectionTitle}" Margin="0,0,0,6"/>
                                        <TextBlock Grid.Column="1" Text="Defaults are suitable for most CT studies"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="11"/>
                                    </Grid>

                                    <!-- Patient -->
                                    <TextBlock Text="Patient" Foreground="{StaticResource AccentLightBrush}"
                                               FontWeight="SemiBold" FontSize="12" Margin="0,0,0,4"/>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                            <TextBlock Text="Patient ID" Style="{StaticResource OptionLabel}"/>
                                            <TextBox Text="{Binding RawPatientId, UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="4,0">
                                            <TextBlock Text="Patient Name" Style="{StaticResource OptionLabel}"/>
                                            <TextBox Text="{Binding RawPatientName, UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Margin="8,0,0,0">
                                            <TextBlock Text="Sex" Style="{StaticResource OptionLabel}"/>
                                            <ComboBox SelectedValue="{Binding RawPatientSex}" SelectedValuePath="Content"
                                                      Background="{StaticResource BgMediumBrush}" Foreground="White"
                                                      BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                                <ComboBoxItem Content="O"/>
                                                <ComboBoxItem Content="M"/>
                                                <ComboBoxItem Content="F"/>
                                            </ComboBox>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Study -->
                                    <TextBlock Text="Study" Foreground="{StaticResource AccentLightBrush}"
                                               FontWeight="SemiBold" FontSize="12" Margin="0,4,0,4"/>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                            <TextBlock Text="Study Date (YYYYMMDD)" Style="{StaticResource OptionLabel}"/>
                                            <TextBox Text="{Binding RawStudyDate, UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="4,0">
                                            <TextBlock Text="Study ID" Style="{StaticResource OptionLabel}"/>
                                            <TextBox Text="{Binding RawStudyId, UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Margin="8,0,0,0">
                                            <TextBlock Text="Study Description" Style="{StaticResource OptionLabel}"/>
                                            <TextBox Text="{Binding RawStudyDescription, UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Geometry -->
                                    <TextBlock Text="Geometry &amp; CT Values" Foreground="{StaticResource AccentLightBrush}"
                                               FontWeight="SemiBold" FontSize="12" Margin="0,4,0,4"/>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                            <TextBlock Text="Pixel Spacing" Style="{StaticResource OptionLabel}"/>
                                            <TextBox Text="{Binding RawPixelSpacing, UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="4,0">
                                            <TextBlock Text="Slice Thickness" Style="{StaticResource OptionLabel}"/>
                                            <TextBox Text="{Binding RawSliceThickness, UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Margin="4,0">
                                            <TextBlock Text="Rescale Intercept" Style="{StaticResource OptionLabel}"/>
                                            <TextBox Text="{Binding RawRescaleIntercept, UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="3" Margin="4,0,0,0">
                                            <TextBlock Text="Rescale Slope" Style="{StaticResource OptionLabel}"/>
                                            <TextBox Text="{Binding RawRescaleSlope, UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>
                                    </Grid>

                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                            <TextBlock Text="Window Center" Style="{StaticResource OptionLabel}"/>
                                            <TextBox Text="{Binding RawWindowCenter, UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="4,0">
                                            <TextBlock Text="Window Width" Style="{StaticResource OptionLabel}"/>
                                            <TextBox Text="{Binding RawWindowWidth, UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Margin="4,0">
                                            <TextBlock Text="KVP" Style="{StaticResource OptionLabel}"/>
                                            <TextBox Text="{Binding RawKvp, UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="3" Margin="4,0,0,0">
                                            <TextBlock Text="Model" Style="{StaticResource OptionLabel}"/>
                                            <TextBox Text="{Binding RawManufacturerModel, UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Slice Range -->
                                    <TextBlock Text="Slice Range" Foreground="{StaticResource AccentLightBrush}"
                                               FontWeight="SemiBold" FontSize="12" Margin="0,6,0,4"/>
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                            <TextBlock Text="Start Slice (0-based)" Style="{StaticResource OptionLabel}"/>
                                            <TextBox Text="{Binding RawSliceStart, UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                            <TextBlock Text="End Slice (0-based)" Style="{StaticResource OptionLabel}"/>
                                            <TextBox Text="{Binding RawSliceEnd, UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" VerticalAlignment="Bottom" Orientation="Horizontal"
                                                    Margin="0,0,8,0">
                                            <Button Content="All" Width="36" Padding="2,4" FontSize="11" Margin="0,0,4,0"
                                                    Click="RawSliceAll_Click" ToolTip="Set range to all slices"/>
                                            <Button Content="±50" Width="36" Padding="2,4" FontSize="11" Margin="0,0,4,0"
                                                    Click="RawSliceCenter50_Click" ToolTip="50 slices around current preview"/>
                                            <Button Content="±100" Width="38" Padding="2,4" FontSize="11"
                                                    Click="RawSliceCenter100_Click" ToolTip="100 slices around current preview"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="3" Text="{Binding RawSliceRangeDisplay}"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   FontWeight="SemiBold" FontSize="12"
                                                   VerticalAlignment="Bottom" HorizontalAlignment="Right"
                                                   Margin="0,0,0,0"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Action Buttons -->
                            <Border Grid.Row="3" Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Output folder -->
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="Output:" Style="{StaticResource OptionLabel}" Margin="0,0,6,0"/>
                                        <TextBlock Text="{Binding RawOutputFolder, FallbackValue='Not set'}"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                                   MaxWidth="280" FontSize="11"/>
                                        <Button Content="Set..." Command="{Binding SelectRawOutputFolderCommand}"
                                                Margin="8,0,0,0" Padding="8,4" FontSize="11"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="Clear Log" Command="{Binding ClearLogCommand}"
                                            Margin="0,0,8,0" Padding="14,8"
                                            Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <Button Grid.Column="2" Content="Preview"
                                            Command="{Binding RawPreviewCommand}"
                                            IsEnabled="{Binding RawIsConverting, Converter={StaticResource BoolInverse}}"
                                            Style="{StaticResource AccentButton}" Margin="0,0,8,0" MinWidth="100"/>
                                    <Button Grid.Column="3" Content="▶ Convert"
                                            Command="{Binding RawConvertCommand}"
                                            IsEnabled="{Binding RawIsPreviewLoaded}"
                                            Style="{StaticResource AccentButton}" MinWidth="120"/>
                                </Grid>
                            </Border>

                            <!-- Preview Area -->
                            <Border Grid.Row="4" Style="{StaticResource CardPanel}"
                                    Visibility="{Binding RawIsPreviewLoaded, Converter={StaticResource BoolToVis}}"
                                    Margin="0,0,0,12">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="PREVIEW - Volume Statistics" Style="{StaticResource SectionTitle}" Margin="0,0,0,8"/>
                                        <Button Grid.Column="1" Content="Cancel"
                                                Command="{Binding RawCancelPreviewCommand}"
                                                Style="{StaticResource DangerButton}" Margin="0,0,0,8"/>
                                    </Grid>

                                    <Grid Grid.Row="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Statistics -->
                                        <Border Grid.Column="0" Margin="0,0,12,0">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Grid Grid.Row="0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Dimensions:"
                                                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,16,4"/>
                                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding RawPreviewDimensions}"
                                                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Slices:"
                                                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,16,4"/>
                                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding RawPreviewSlices}"
                                                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="File Size:"
                                                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,16,4"/>
                                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding RawPreviewFileSize}"
                                                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Min:"
                                                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,16,4"/>
                                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding RawPreviewMin}"
                                                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Max:"
                                                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,16,4"/>
                                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding RawPreviewMax}"
                                                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Mean:"
                                                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,16,4"/>
                                                    <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding RawPreviewMean}"
                                                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                                                    <TextBlock Grid.Row="6" Grid.Column="0" Text="StdDev:"
                                                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,16,0"/>
                                                    <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding RawPreviewStdDev}"
                                                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,0"/>
                                                </Grid>

                                                <!-- Slice Slider -->
                                                <Grid Grid.Row="1" Margin="0,10,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="Slice:"
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                    <Slider Grid.Column="1"
                                                            Minimum="0" Maximum="{Binding RawSliceMax}"
                                                            Value="{Binding RawPreviewSliceIndex, UpdateSourceTrigger=PropertyChanged}"
                                                            TickFrequency="1" IsSnapToTickEnabled="True"
                                                            SmallChange="1" LargeChange="10"
                                                            VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding RawPreviewSliceIndex}"
                                                               Foreground="{StaticResource AccentBrush}"
                                                               FontWeight="Bold"
                                                               VerticalAlignment="Center" Margin="8,0,0,0" MinWidth="30"/>
                                                </Grid>
                                            </Grid>
                                        </Border>

                                        <!-- Thumbnail -->
                                        <Border Grid.Column="1" BorderBrush="{StaticResource BorderBrush}"
                                                BorderThickness="1" CornerRadius="4"
                                                Background="{StaticResource SurfaceBrush}" Padding="4"
                                                Width="260" Height="260">
                                            <Grid>
                                                <Image Source="{Binding RawSliceThumbnail}"
                                                       Width="252" Height="252"
                                                       Stretch="Uniform"
                                                       ToolTip="Middle slice (window: center=40, width=400)"/>
                                                <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                                                           FontSize="10" HorizontalAlignment="Center"
                                                           VerticalAlignment="Bottom" Margin="0,0,0,4">
                                                    <Run Text="Slice "/>
                                                    <Run Text="{Binding RawPreviewSliceIndex, Mode=OneWay}"/>
                                                    <Run Text="/"/>
                                                    <Run Text="{Binding RawSliceMax, Mode=OneWay}"/>
                                                </TextBlock>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- Log -->
                            <Border Grid.Row="5" Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="LOG" Style="{StaticResource SectionTitle}" Margin="0,0,0,4"/>
                                    <ListBox Grid.Row="1" ItemsSource="{Binding LogEntries}" MaxHeight="140"
                                             Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}"
                                             BorderThickness="1" FontFamily="Consolas" FontSize="11"
                                             Foreground="{StaticResource TextSecondaryBrush}"
                                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                             VirtualizingPanel.IsVirtualizing="True"
                                             VirtualizingPanel.VirtualizationMode="Recycling">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" TextWrapping="NoWrap"/>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </ScrollViewer>
            </Grid>

            <!-- ===== Status Bar ===== -->
            <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}"
                    BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}"
                    Padding="16,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <ProgressBar Grid.Column="0"
                                 Value="{Binding ProgressCurrent}"
                                 Maximum="{Binding ProgressTotal}"
                                 Height="6" Margin="0,0,16,0"
                                 IsIndeterminate="{Binding IsScanning}"/>

                    <TextBlock Grid.Column="1"
                               Text="{Binding ProgressStatus, FallbackValue='Ready'}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11" VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
